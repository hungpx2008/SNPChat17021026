DATABASE_URL=postgresql+asyncpg://chatsnp:12345678@localhost:5432/chatsnp
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
CHAT_MAX_SESSIONS=100
CHAT_CACHE_WINDOW=20
CHAT_CHUNK_SIZE=512
# Docling Adaptive Chunking (optional overrides)
DOCLING_CHUNK_MAX_TOKENS=512
DOCLING_CHUNK_MERGE_PEERS=true
DOCLING_TABLE_MARKDOWN_MAX_COLS=4
DOCLING_TABLE_MARKDOWN_MAX_CELLS=36
DOCLING_TABLE_GROUP_KEY_HINTS=type,category,item,service,description,name,code,id,loai,muc,dich vu
DOCLING_TABLE_NORMALIZE_VALUES=true
DOCLING_PREFIX_HEADING_ROWKEY=true
DOCLING_GROUP_LOCK_ENABLED=true
DOCLING_GROUP_LOCK_MAX_CHARS=1800
CORS_ALLOW_ORIGINS=["http://localhost:9002","http://127.0.0.1:9002","https://improve-calendars-wells-reviewer.trycloudflare.com"]
